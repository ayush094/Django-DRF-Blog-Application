SECRET_KEY=your-django-secret-key-here
DEBUG=False
ALLOWED_HOSTS=your-domain.com,localhost,127.0.0.1
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASSWORD=your_database_password
DB_HOST=your_database_host
DB_PORT=5432
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
ANTHROPIC_API_KEY=your-anthropic-api-key
# Google Cloud Text-to-Speech credentials (required for audio feature)
# Get service account key JSON from GCP Console and set path here
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/google-credentials.json
CELERY_BROKER_URL=redis://your-redis-host:6377/0
CELERY_RESULT_BACKEND=redis://your-redis-host:6377/0
